{
  "permissions": {
    "allow": [
      "Bash(./wfweb:*)",
      "Bash(./virtualrig:*)",
      "Bash(./tools/virtualrig/virtualrig:*)",
      "Bash(./scripts/testrig.sh:*)",
      "Bash(nm:*)",
      "Bash(pgrep -af @playwright/mcp)",
      "Bash(pkill -f @playwright/mcp)",
      "Bash(npx -y @playwright/mcp@latest --help)",
      "Bash(curl -sk -o /dev/null -w * https://127.0.0.1:*)",
      "Bash(curl -sk * https://127.0.0.1:*)",

      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_press_key",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_close",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_tabs"
    ]
  },
  "enabledMcpjsonServers": ["playwright"],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/build-and-test.sh",
            "timeout": 300,
            "statusMessage": "Building wfweb..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/changelog-reminder.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/precommit-build-check.sh",
            "timeout": 30,
            "if": "Bash(git commit:*)"
          }
        ]
      }
    ]
  }
}
